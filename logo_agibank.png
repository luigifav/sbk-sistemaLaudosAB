"""
importar_excel.py
Importa e cruza os dois Excel para o banco SQLite.

Uso:
  python importar_excel.py data.xlsx                   (só contratos)
  python importar_excel.py data.xlsx data__7_.xlsx     (cruza os dois)

Requisitos: pip install openpyxl pandas
"""

import sys, sqlite3, warnings, io, csv
import pandas as pd
from datetime import datetime

warnings.filterwarnings("ignore")
DB_ARQUIVO = "banco_laudos.db"

